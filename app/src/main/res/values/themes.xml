<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.BioProtect" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/bp_primary</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/bp_surface</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
    </style>

    <style name="Theme.BioProtect.Lock" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowIsTranslucent">false</item>
        <item name="android:windowShowWallpaper">false</item>
        <item name="android:windowDisablePreview">true</item>
        <item name="android:windowBackground">@color/bp_surface</item>
    </style>
</resources>
